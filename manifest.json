{
  "manifest_version": 3,
  "name": "AI to Glorified Autocomplete",
  "short_name": "Glorified Autocomplete",
  "description": "Replaces AI hype terminology with what it actually is.",
  "version": "1.1",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon32.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "all_frames": true,
      "js": ["replacements.js", "content_script.js"],
      "run_at": "document_end"
    }
  ]
}
